{
  "name": "tbsgroup-backend",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm exec prisma generate && pnpm run build"
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environment": {
    "NODE_ENV": "production",
    "PORT": 8080
  },
  "region": "singapore",
  "healthcheck": {
    "path": "/health",
    "timeout": 30
  }
}
